#!/usr/bin/env tsx

import { join } from 'node:path';
import { writeFileSync } from 'node:fs';
import { generateAllConfigs } from '../src/circleci.ts';
import { getWorkspacePackageInfo } from '../src/pnpm.ts';

const workspaceRoot = join(import.meta.dirname, '..', '..', '..');

async function main() {
  const packageInfo = getWorkspacePackageInfo(workspaceRoot);
  const configs = generateAllConfigs(packageInfo);
  for (const [filePath, fileContents] of configs.entries()) {
    console.log(`Writing CircleCI config to ${filePath}`);
    writeFileSync(filePath, fileContents);
  }
}

main().catch((error) => {
  console.error(error);
  process.exit(1);
});
