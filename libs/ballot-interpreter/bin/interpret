#!/usr/bin/env node

// @ts-check

require('esbuild-runner').install({
  type: 'transform',
});

require('../src/bubble-ballot-ts/cli')
  .main(process.argv.slice(2))
  .then(
    (code) => {
      process.exitCode = code;
    },
    (err) => {
      console.error(err);
      process.exit(1);
    }
  );
