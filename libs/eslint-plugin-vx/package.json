{
  "name": "eslint-plugin-vx",
  "version": "1.0.0",
  "description": "VotingWorks monorepo rules for ESLint",
  "keywords": [],
  "license": "GPL-3.0-only",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "type-check": "tsgo --build",
    "type-check:watch": "tsgo --build --watch",
    "build": "is-ci build:ci build:dev",
    "build:ci": "pnpm --filter $npm_package_name... --sequential build:self",
    "build:dev": "pnpm --filter $npm_package_name... build:self",
    "build:self": "tsgo --build tsconfig.build.json",
    "build:watch": "tsgo --build --watch tsconfig.build.json",
    "clean": "pnpm --filter $npm_package_name... clean:self",
    "clean:self": "rm -rf build && tsgo --build --clean tsconfig.build.json",
    "lint": "echo eslint-plugin-vs linting temporarily disabled",
    "lint:fix": "echo eslint-plugin-vs linting temporarily disabled",
    "test": "is-ci test:ci test:watch",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9",
    "@typescript-eslint/parser": "^8",
    "@typescript-eslint/utils": "^8",
    "comment-parser": "^1.4.0",
    "eslint-config-airbnb": "^19",
    "eslint-config-airbnb-base": "^15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "3.6.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.4.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8"
  },
  "devDependencies": {
    "@types/node": "20.17.31",
    "@types/react": "18.3.3",
    "@typescript-eslint/rule-tester": "^8.57.2",
    "@vitest/coverage-istanbul": "^3.1.4",
    "is-ci-cli": "2.2.0",
    "react": "18.3.1",
    "vitest": "^3.1.4"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "packageManager": "pnpm@8.15.5"
}
