#!/usr/bin/env node

// @ts-check

require('esbuild-runner').install({
  type: 'transform',
});

const { stdout, stderr } = process;
require('../src/backup/cli')
  .main(process.argv, { stdout, stderr })
  .then((code) => {
    process.exitCode = code;
  })
  .catch((error) => {
    stderr.write(`${error}\n`);
    process.exit(1);
  });
